{
  "name": "medyanes360-factory",
  "version": "1.0.0",
  "private": true,
  "description": "MEDYANES 360 App Factory - ortak cekirdek uzerine coklu mobil uygulama monoreposu",
  "scripts": {
    "verify": "pnpm run verify:test && pnpm run verify:typecheck && pnpm run verify:lint",
    "verify:test": "pnpm --filter \"./packages/**\" -r test",
    "verify:typecheck": "pnpm -r typecheck",
    "verify:lint": "eslint .",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "new-app": "node scripts/yeni-uygulama.mjs",
    "onizleme": "node scripts/ekran-onizleme.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.5.3",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "playwright": "^1.52.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
